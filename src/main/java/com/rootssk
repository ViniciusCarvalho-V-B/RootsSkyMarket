package com.rootssky.market.util;

import com.rootssky.market.RootsSkyMarket;
import org.bukkit.configuration.file.FileConfiguration;

public class ConfigManager {
    
    public static void loadConfig(RootsSkyMarket plugin) {
        FileConfiguration config = plugin.getConfig();
        
        // Load configuration options for the visual system
        config.addDefault("market.visual.enabled", true);
        config.addDefault("market.visual.update_interval", 5);
        config.addDefault("market.visual.indicator_style", " arrows");
        config.addDefault("market.visual.indicator_color", "default");
        
        // Save the updated configuration
        config.options().copyDefaults(true);
        plugin.saveConfig();
    }
}